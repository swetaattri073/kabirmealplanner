# Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this-in-production

# Database (optional - defaults to SQLite)
# DATABASE_URL=sqlite:///toddler_meals.db

# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/toddler_meals

# --- Social Login (optional) ---
# Google: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://YOUR_DOMAIN/authorize/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook / Instagram (Meta): https://developers.facebook.com/
# Authorized redirect URI: https://YOUR_DOMAIN/authorize/facebook
# Note: Consumer Instagram sign-in uses Facebook Login
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
