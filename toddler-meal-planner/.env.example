# Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this-in-production

# Set to true ONLY when the site is served over HTTPS.
# Leave false/unset for HTTP Docker access (e.g. http://your-server-ip).
# SESSION_COOKIE_SECURE=false

# Database (optional)
# Default: SQLite at instance/toddler_meals.db (persists with Docker -v ~/meal-data:/app/instance)
# DATABASE_URL=sqlite:////app/instance/toddler_meals.db
# For PostgreSQL (recommended for larger production):
# DATABASE_URL=postgresql://user:password@localhost:5432/toddler_meals

# Auth: email/password only (social login removed for now)

# --- Chat assistant (OpenAI) ---
# Get a key: https://platform.openai.com/api-keys
#
# Production (persists across redeploys with the DB volume):
#   cp .env.example ~/meal-data/.env
#   # put OPENAI_API_KEY=... in ~/meal-data/.env
#   docker run ... -v ~/meal-data:/app/instance --env-file ~/meal-data/.env ...
# The app also auto-loads /app/instance/.env from that volume.
#
# Local development: copy this file to .env in this folder instead.
OPENAI_API_KEY=
# Optional model override (default gpt-4o-mini)
# OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Optional USDA FoodData Central (nutrition lookups) ---
# Sign up: https://fdc.nal.usda.gov/api-key-signup/
# Without this, USDA endpoints use DEMO_KEY (low rate limits).
# Existing Open Food Facts enrichment still works either way.
USDA_FDC_API_KEY=
